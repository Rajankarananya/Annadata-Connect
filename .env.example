# ==========================================
# Core Application (FastAPI Backend)
# ==========================================
APP_NAME=Annadata Connect
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ==========================================
# PostgreSQL + PostGIS
# ==========================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_key_here
POSTGRES_DB=agri_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGIS_REQUIRED=true
DATABASE_URL=postgresql+psycopg://postgres:your_key_here@localhost:5432/agri_db

# ==========================================
# JWT Authentication (Role-Based)
# Roles: farmer, field_officer, admin
# ==========================================
JWT_SECRET_KEY=your_key_here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
AUTH_ALLOWED_ROLES=farmer,field_officer,admin

# ==========================================
# Frontend (React + Vite + Tailwind)
# Note: Vite-exposed vars must start with VITE_
# ==========================================
VITE_APP_NAME=Annadata Connect
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_DEFAULT_LANGUAGE=en

# ==========================================
# ML Inference (EfficientNet-B0 TFLite)
# ==========================================
TFLITE_MODEL_PATH=./models/efficientnet_b0_crop_damage.tflite
TFLITE_LABELS_PATH=./models/labels.txt
MODEL_INPUT_SIZE=224
MODEL_CONFIDENCE_THRESHOLD=0.60

# ==========================================
# LLM Chatbot (Ollama + LangChain + Chroma)
# ==========================================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_TEMPERATURE=0.2
OLLAMA_NUM_CTX=4096
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your_key_here
CHROMA_PERSIST_DIRECTORY=./data/chroma
RAG_COLLECTION_NAME=annadata_connect_docs
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200
RAG_TOP_K=4

# ==========================================
# Translation (Bhashini API)
# Hindi + Marathi language support
# ==========================================
BHASHINI_API_BASE_URL=https://bhashini.gov.in
BHASHINI_API_KEY=your_key_here
BHASHINI_USER_ID=your_user_id_here
BHASHINI_SOURCE_LANGUAGE=en
BHASHINI_TARGET_LANGUAGES=hi,mr

# ==========================================
# Weather Service (Open-Meteo)
# No API key required
# ==========================================
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1/forecast
WEATHER_HOURLY_FIELDS=temperature_2m,soil_temperature_0cm,rain,surface_pressure,cloud_cover,visibility,evapotranspiration,temperature_80m,wind_speed_10m,wind_gusts_10m,wind_direction_10m,wind_direction_80m,precipitation,precipitation_probability,relative_humidity_2m
WEATHER_DEFAULT_TIMEZONE=auto

# ==========================================
# Optional Admin Bootstrap
# ==========================================
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your_key_here