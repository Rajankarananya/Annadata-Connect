{
  "info": {
    "name": "Annadata Connect API",
    "description": "Postman collection for Annadata Connect smart agriculture administration system.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Ravi Patil\",\n  \"email\": \"ravi@example.com\",\n  \"password\": \"your_password_here\",\n  \"role\": \"farmer\",\n  \"phone\": \"9876543210\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/api/v1/auth/register"
          },
          "response": []
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"ravi@example.com\",\n  \"password\": \"your_password_here\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/api/v1/auth/login"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Farmers",
      "item": [
        {
          "name": "Create Farmer Profile",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Ravi Patil\",\n  \"district\": \"Nashik\",\n  \"village\": \"Sinnar\",\n  \"land_area_acres\": 2.5,\n  \"primary_crop\": \"soybean\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/api/v1/farmers"
          },
          "response": []
        },
        {
          "name": "Get Farmer By ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/api/v1/farmers/{{farmerId}}"
          },
          "response": []
        },
        {
          "name": "Update Farmer Profile",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"district\": \"Pune\",\n  \"village\": \"Mulshi\",\n  \"land_area_acres\": 3.0\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/api/v1/farmers/{{farmerId}}"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Claims",
      "item": [
        {
          "name": "Submit Crop Damage Claim",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "farmer_id",
                  "value": "{{farmerId}}",
                  "type": "text"
                },
                {
                  "key": "crop_type",
                  "value": "soybean",
                  "type": "text"
                },
                {
                  "key": "district",
                  "value": "Nashik",
                  "type": "text"
                },
                {
                  "key": "image",
                  "type": "file",
                  "src": ""
                }
              ]
            },
            "url": "{{baseUrl}}/api/v1/claims"
          },
          "response": []
        },
        {
          "name": "Get Claim Details",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/api/v1/claims/{{claimId}}"
          },
          "response": []
        },
        {
          "name": "Update Claim Status",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"approved\",\n  \"remarks\": \"Verified by field officer\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/api/v1/claims/{{claimId}}/status"
          },
          "response": []
        },
        {
          "name": "List All Claims (Admin)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/api/v1/claims"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Grievances",
      "item": [
        {
          "name": "Submit Grievance",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"farmer_id\": \"{{farmerId}}\",\n  \"category\": \"payment_delay\",\n  \"description\": \"Claim payout not received in expected timeline.\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/api/v1/grievances"
          },
          "response": []
        },
        {
          "name": "List All Grievances (Admin)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/api/v1/grievances"
          },
          "response": []
        }
      ]
    },
    {
      "name": "AI / ML",
      "item": [
        {
          "name": "Analyze Crop Image",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "image",
                  "type": "file",
                  "src": ""
                },
                {
                  "key": "crop_type",
                  "value": "soybean",
                  "type": "text"
                }
              ]
            },
            "url": "{{baseUrl}}/api/v1/analyze"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Chatbot",
      "item": [
        {
          "name": "Chat With LLM",
          "request": {
            "method": "POST",
            "description": "Primary chat endpoint. Send message + history array in body. Set stream=true to receive SSE token stream.",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"My soybean leaves are turning yellow. What should I do?\",\n  \"history\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"I am a farmer from Nashik.\"\n    },\n    {\n      \"role\": \"assistant\",\n      \"content\": \"Sure, tell me your crop issue.\"\n    }\n  ],\n  \"language\": \"en\",\n  \"stream\": false\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/api/v1/chat"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Analytics",
      "item": [
        {
          "name": "Analytics Summary",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/api/v1/analytics/summary"
          },
          "response": []
        },
        {
          "name": "Analytics Risk Map (GeoJSON)",
          "request": {
            "method": "GET",
            "description": "Returns district-level weather risk as GeoJSON FeatureCollection. Optional `districts` query accepts comma-separated district names (e.g. Nashik,Pune,Nagpur).",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/analytics/risk-map?districts={{districts}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "analytics",
                "risk-map"
              ],
              "query": [
                {
                  "key": "districts",
                  "value": "{{districts}}",
                  "description": "Optional comma-separated district names"
                }
              ]
            }
          },
          "response": [
            {
              "name": "Sample GeoJSON Response",
              "originalRequest": {
                "method": "GET",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{token}}"
                  }
                ],
                "url": {
                  "raw": "{{baseUrl}}/api/v1/analytics/risk-map?districts=Nashik,Pune",
                  "host": [
                    "{{baseUrl}}"
                  ],
                  "path": [
                    "api",
                    "v1",
                    "analytics",
                    "risk-map"
                  ],
                  "query": [
                    {
                      "key": "districts",
                      "value": "Nashik,Pune"
                    }
                  ]
                }
              },
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": "{\n  \"type\": \"FeatureCollection\",\n  \"name\": \"district_weather_risk\",\n  \"features\": [\n    {\n      \"type\": \"Feature\",\n      \"id\": \"Nashik\",\n      \"properties\": {\n        \"district\": \"Nashik\",\n        \"state\": \"Maharashtra\",\n        \"risk_score\": 67,\n        \"precip_anomaly_mm\": 12.4,\n        \"avg_precip_30d_mm\": 8.1,\n        \"temp_anomaly_c\": 1.9,\n        \"risk_level\": \"moderate\"\n      },\n      \"geometry\": {\n        \"type\": \"Point\",\n        \"coordinates\": [73.7909, 20.0112]\n      }\n    },\n    {\n      \"type\": \"Feature\",\n      \"id\": \"Pune\",\n      \"properties\": {\n        \"district\": \"Pune\",\n        \"state\": \"Maharashtra\",\n        \"risk_score\": 42,\n        \"precip_anomaly_mm\": 6.8,\n        \"avg_precip_30d_mm\": 9.7,\n        \"temp_anomaly_c\": 1.1,\n        \"risk_level\": \"moderate\"\n      },\n      \"geometry\": {\n        \"type\": \"Point\",\n        \"coordinates\": [73.8567, 18.5204]\n      }\n    }\n  ],\n  \"metadata\": {\n    \"source\": \"open-meteo\",\n    \"generated_at\": \"realtime\",\n    \"count\": 2\n  }\n}"
            }
          ]
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8000"
    },
    {
      "key": "token",
      "value": "your_jwt_token_here"
    },
    {
      "key": "farmerId",
      "value": "1"
    },
    {
      "key": "claimId",
      "value": "1"
    },
    {
      "key": "districts",
      "value": ""
    }
  ]
}